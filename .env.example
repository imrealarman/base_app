APP_ENV=dev
API_BASE_URL=https://api.dev.example.com
APP_TEXT_DIRECTION=ltr

# When true, bootstrap() throws if any required key (see env_validator.dart)
# is missing instead of just logging a warning. Keep false for local dev
# convenience; set true in CI/production so misconfiguration fails loudly.
STRICT_ENV_VALIDATION=false

FEATURE_ANALYTICS_ENABLED=false
FEATURE_DARK_MODE_TOGGLE=true
FEATURE_SETTINGS_SCREEN=true
